ANTHROPIC_API_KEY=your_api_key_here
BAARA_API_KEY=                        # Optional: set to require auth on API endpoints
BAARA_AUTH_MODE=subscription          # subscription (Claude CLI, default) or api_key (per-token billing)
DEFAULT_EXECUTION_MODE=direct
PORT=3000
HOST=0.0.0.0
NEXUS_DIR=~/.nexus                    # Baara home directory (DB, logs, sessions, briefings)
DB_PATH=                              # Override DB location (default: $NEXUS_DIR/baara.db)
STATIC_DIR=web
